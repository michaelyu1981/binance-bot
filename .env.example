# Binance read-only API first
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Optional Telegram alerts. Leave empty to use local print/log alerts only.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional dashboard login. Leave password empty to disable login locally.
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=

# Bot mode
BOT_MODE=read_only
DRY_RUN=true
ENABLE_LIVE_TRADING=false
